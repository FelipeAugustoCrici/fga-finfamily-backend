// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        String               @id @default(uuid())
  name      String
  type      String               @default("expense")
  familyId  String?
  family    Family?              @relation(fields: [familyId], references: [id])
  createdAt DateTime             @default(now())
  expenses  Expense[]
  budgets   Budget[]
  purchases CreditCardPurchase[]
}

model Family {
  id          String               @id @default(uuid())
  name        String
  members     Person[]
  categories  Category[]
  creditCards CreditCard[]
  purchases   CreditCardPurchase[]
  createdAt   DateTime             @default(now())
}

model Person {
  id            String               @id @default(uuid())
  name          String
  phone         String?
  email         String?
  cpf           String?
  birthDate     DateTime?
  userId        String? // Cognito sub
  familyId      String
  family        Family               @relation(fields: [familyId], references: [id])
  salaries      Salary[]
  extraIncomes  ExtraIncome[]
  incomes       Income[]
  incomeSources IncomeSource[]
  expenses      Expense[]
  recurrings    RecurringExpense[]
  creditCards   CreditCard[]
  purchases     CreditCardPurchase[]
  createdAt     DateTime             @default(now())

  @@index([userId])
}

model IncomeSource {
  id          String    @id @default(uuid())
  description String
  value       Float
  type        String // 'fixed', 'variable', 'temporary'
  isRecurring Boolean   @default(true)
  startDate   DateTime
  endDate     DateTime?
  active      Boolean   @default(true)
  personId    String
  person      Person    @relation(fields: [personId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  incomes     Income[]
}

model Income {
  id          String        @id @default(uuid())
  description String
  value       Float
  date        DateTime
  month       Int
  year        Int
  type        String // 'fixed', 'variable', 'temporary'
  personId    String
  person      Person        @relation(fields: [personId], references: [id])
  sourceId    String?
  source      IncomeSource? @relation(fields: [sourceId], references: [id])
  createdAt   DateTime      @default(now())
  is_deleted  Boolean       @default(false)
  dt_deleted  DateTime?

  @@index([month, year])
}

model Salary {
  id         String    @id @default(uuid())
  personId   String
  person     Person    @relation(fields: [personId], references: [id])
  value      Float
  month      Int
  year       Int
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  is_deleted Boolean   @default(false)
  dt_deleted DateTime?

  @@unique([personId, month, year])
}

model ExtraIncome {
  id          String    @id @default(uuid())
  description String
  value       Float
  date        DateTime
  month       Int
  year        Int
  personId    String
  person      Person    @relation(fields: [personId], references: [id])
  createdAt   DateTime  @default(now())
  is_deleted  Boolean   @default(false)
  dt_deleted  DateTime?

  @@index([month, year])
}

model Expense {
  id           String    @id @default(uuid())
  description  String
  value        Float
  categoryName String
  categoryId   String?
  category     Category? @relation(fields: [categoryId], references: [id])
  type         String // 'fixed' | 'variable'
  date         DateTime
  month        Int
  year         Int
  isCreditCard Boolean   @default(false)
  creditCardId String?
  personId     String
  person       Person    @relation(fields: [personId], references: [id])
  status       String    @default("PENDING") // 'PENDING' | 'PAID' | 'OVERDUE'
  createdAt    DateTime  @default(now())
  is_deleted   Boolean   @default(false)
  dt_deleted   DateTime?

  recurringId String?
  recurring   RecurringExpense? @relation(fields: [recurringId], references: [id])

  @@index([month, year])
}

model RecurringExpense {
  id           String    @id @default(uuid())
  description  String
  value        Float
  categoryName String
  personId     String
  person       Person    @relation(fields: [personId], references: [id])
  startDate    DateTime
  endDate      DateTime?
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  expenses     Expense[]
}

model Goal {
  id            String             @id @default(uuid())
  description   String
  type          String             @default("savings") // savings | debt | purchase | investment
  targetValue   Float
  currentValue  Float              @default(0)
  deadline      DateTime?
  familyId      String?
  personId      String?
  status        String             @default("active") // active | completed | archived
  createdAt     DateTime           @default(now())
  contributions GoalContribution[]
}

model GoalContribution {
  id          String   @id @default(uuid())
  goalId      String
  goal        Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  value       Float
  date        DateTime @default(now())
  observation String?
  createdAt   DateTime @default(now())
}

model Budget {
  id           String    @id @default(uuid())
  categoryName String
  categoryId   String?
  category     Category? @relation(fields: [categoryId], references: [id])
  familyId     String?
  limitValue   Float
  month        Int
  year         Int
  createdAt    DateTime  @default(now())

  @@unique([categoryName, month, year])
}

model CreditCard {
  id             String                @id @default(uuid())
  familyId       String?
  family         Family?               @relation(fields: [familyId], references: [id])
  ownerId        String?
  owner          Person?               @relation(fields: [ownerId], references: [id])
  name           String
  bank           String?
  brand          String?               @default("other")
  color          String?               @default("#334155")
  limitAmount    Float
  availableLimit Float
  closingDay     Int
  dueDay         Int
  isActive       Boolean               @default(true)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  invoices       CreditCardInvoice[]
  purchases      CreditCardPurchase[]
}

model CreditCardInvoice {
  id             String                    @id @default(uuid())
  creditCardId   String
  creditCard     CreditCard                @relation(fields: [creditCardId], references: [id])
  referenceMonth Int
  referenceYear  Int
  closingDate    DateTime
  dueDate        DateTime
  totalAmount    Float                     @default(0)
  paidAmount     Float                     @default(0)
  status         String                    @default("open") // open | closed | paid | overdue
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  installments   CreditCardInstallment[]

  @@unique([creditCardId, referenceMonth, referenceYear])
}

model CreditCardPurchase {
  id           String                    @id @default(uuid())
  creditCardId String
  creditCard   CreditCard                @relation(fields: [creditCardId], references: [id])
  familyId     String?
  family       Family?                   @relation(fields: [familyId], references: [id])
  ownerId      String?
  owner        Person?                   @relation(fields: [ownerId], references: [id])
  categoryId   String?
  category     Category?                 @relation(fields: [categoryId], references: [id])
  description  String
  purchaseDate DateTime
  totalAmount  Float
  installments Int                       @default(1)
  observation  String?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  parcels      CreditCardInstallment[]
}

model CreditCardInstallment {
  id                String             @id @default(uuid())
  purchaseId        String
  purchase          CreditCardPurchase @relation(fields: [purchaseId], references: [id])
  invoiceId         String
  invoice           CreditCardInvoice  @relation(fields: [invoiceId], references: [id])
  installmentNumber Int
  totalInstallments Int
  amount            Float
  referenceMonth    Int
  referenceYear     Int
  status            String             @default("pending") // pending | paid
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}
