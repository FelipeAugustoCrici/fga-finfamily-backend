generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        String               @id @default(uuid())
  name      String
  type      String               @default("expense")
  familyId  String?
  family    Family?              @relation(fields: [familyId], references: [id])
  createdAt DateTime             @default(now())
  expenses  Expense[]
  budgets   Budget[]
  purchases CreditCardPurchase[]

  @@index([familyId])
  @@index([type])
}

model Family {
  id          String               @id @default(uuid())
  name        String
  members     Person[]
  categories  Category[]
  creditCards CreditCard[]
  purchases   CreditCardPurchase[]
  createdAt   DateTime             @default(now())
}

model Person {
  id            String               @id @default(uuid())
  name          String
  phone         String?
  email         String?
  cpf           String?
  birthDate     DateTime?
  userId        String?
  hasAccess     Boolean              @default(false)
  familyId      String
  family        Family               @relation(fields: [familyId], references: [id])
  salaries      Salary[]
  extraIncomes  ExtraIncome[]
  incomes       Income[]
  incomeSources IncomeSource[]
  expenses      Expense[]
  recurrings    RecurringExpense[]
  creditCards   CreditCard[]
  purchases     CreditCardPurchase[]
  createdAt     DateTime             @default(now())

  @@index([userId])
  @@index([familyId])
}

model IncomeSource {
  id          String    @id @default(uuid())
  description String
  value       Float
  type        String
  isRecurring Boolean   @default(true)
  startDate   DateTime
  endDate     DateTime?
  active      Boolean   @default(true)
  personId    String
  person      Person    @relation(fields: [personId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  incomes     Income[]

  @@index([personId])
  @@index([personId, active])
}

model Income {
  id          String        @id @default(uuid())
  description String
  value       Float
  date        DateTime
  month       Int
  year        Int
  type        String
  personId    String
  person      Person        @relation(fields: [personId], references: [id])
  sourceId    String?
  source      IncomeSource? @relation(fields: [sourceId], references: [id])
  createdAt   DateTime      @default(now())
  is_deleted  Boolean       @default(false)
  dt_deleted  DateTime?

  @@index([month, year])
  @@index([personId, month, year])
  @@index([personId, is_deleted])
  @@index([sourceId])
}

model Salary {
  id         String    @id @default(uuid())
  personId   String
  person     Person    @relation(fields: [personId], references: [id])
  value      Float
  month      Int
  year       Int
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  is_deleted Boolean   @default(false)
  dt_deleted DateTime?

  @@unique([personId, month, year])
  @@index([personId, is_deleted])
}

model ExtraIncome {
  id          String    @id @default(uuid())
  description String
  value       Float
  date        DateTime
  month       Int
  year        Int
  personId    String
  person      Person    @relation(fields: [personId], references: [id])
  createdAt   DateTime  @default(now())
  is_deleted  Boolean   @default(false)
  dt_deleted  DateTime?

  @@index([month, year])
  @@index([personId, month, year])
  @@index([personId, is_deleted])
}

model Expense {
  id           String    @id @default(uuid())
  description  String
  value        Float
  categoryName String
  categoryId   String?
  category     Category? @relation(fields: [categoryId], references: [id])
  type         String
  date         DateTime
  month        Int
  year         Int
  isCreditCard Boolean   @default(false)
  creditCardId String?
  personId     String
  person       Person    @relation(fields: [personId], references: [id])
  status       String    @default("PENDING")
  createdAt    DateTime  @default(now())
  is_deleted   Boolean   @default(false)
  dt_deleted   DateTime?
  recurringId  String?
  recurring    RecurringExpense? @relation(fields: [recurringId], references: [id])
  isShared     Boolean   @default(true)

  @@index([month, year])
  @@index([personId, month, year])
  @@index([personId, is_deleted])
  @@index([categoryId])
  @@index([status])
  @@index([is_deleted, month, year])
  @@index([creditCardId])
}

model RecurringExpense {
  id           String    @id @default(uuid())
  description  String
  value        Float
  categoryName String
  personId     String
  person       Person    @relation(fields: [personId], references: [id])
  startDate    DateTime
  endDate      DateTime?
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  expenses     Expense[]

  @@index([personId])
  @@index([personId, active])
}

model Goal {
  id            String             @id @default(uuid())
  description   String
  type          String             @default("savings")
  targetValue   Float
  currentValue  Float              @default(0)
  deadline      DateTime?
  familyId      String?
  personId      String?
  status        String             @default("active")
  createdAt     DateTime           @default(now())
  contributions GoalContribution[]

  @@index([familyId])
  @@index([familyId, status])
  @@index([personId])
}

model GoalContribution {
  id          String   @id @default(uuid())
  goalId      String
  goal        Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  value       Float
  date        DateTime @default(now())
  observation String?
  createdAt   DateTime @default(now())

  @@index([goalId])
  @@index([goalId, date])
}

model Budget {
  id           String    @id @default(uuid())
  categoryName String
  categoryId   String?
  category     Category? @relation(fields: [categoryId], references: [id])
  familyId     String?
  limitValue   Float
  month        Int
  year         Int
  createdAt    DateTime  @default(now())

  @@unique([categoryName, month, year])
  @@index([month, year])
  @@index([familyId, month, year])
}

model CreditCard {
  id             String                @id @default(uuid())
  familyId       String?
  family         Family?               @relation(fields: [familyId], references: [id])
  ownerId        String?
  owner          Person?               @relation(fields: [ownerId], references: [id])
  name           String
  bank           String?
  brand          String?               @default("other")
  color          String?               @default("#334155")
  limitAmount    Float
  availableLimit Float
  closingDay     Int
  dueDay         Int
  isActive       Boolean               @default(true)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  invoices       CreditCardInvoice[]
  purchases      CreditCardPurchase[]

  @@index([familyId])
  @@index([familyId, isActive])
  @@index([ownerId])
}

model CreditCardInvoice {
  id             String                  @id @default(uuid())
  creditCardId   String
  creditCard     CreditCard              @relation(fields: [creditCardId], references: [id])
  referenceMonth Int
  referenceYear  Int
  closingDate    DateTime
  dueDate        DateTime
  totalAmount    Float                   @default(0)
  paidAmount     Float                   @default(0)
  status         String                  @default("open")
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  installments   CreditCardInstallment[]

  @@unique([creditCardId, referenceMonth, referenceYear])
  @@index([creditCardId])
  @@index([creditCardId, referenceMonth, referenceYear])
  @@index([status])
  @@index([dueDate])
}

model CreditCardPurchase {
  id           String                  @id @default(uuid())
  creditCardId String
  creditCard   CreditCard              @relation(fields: [creditCardId], references: [id])
  familyId     String?
  family       Family?                 @relation(fields: [familyId], references: [id])
  ownerId      String?
  owner        Person?                 @relation(fields: [ownerId], references: [id])
  categoryId   String?
  category     Category?               @relation(fields: [categoryId], references: [id])
  description  String
  purchaseDate DateTime
  totalAmount  Float
  installments Int                     @default(1)
  observation  String?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  parcels      CreditCardInstallment[]

  @@index([creditCardId])
  @@index([familyId])
  @@index([ownerId])
  @@index([purchaseDate])
}

model CreditCardInstallment {
  id                String             @id @default(uuid())
  purchaseId        String
  purchase          CreditCardPurchase @relation(fields: [purchaseId], references: [id])
  invoiceId         String
  invoice           CreditCardInvoice  @relation(fields: [invoiceId], references: [id])
  installmentNumber Int
  totalInstallments Int
  amount            Float
  referenceMonth    Int
  referenceYear     Int
  status            String             @default("pending")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([purchaseId])
  @@index([invoiceId])
  @@index([referenceMonth, referenceYear])
  @@index([status])
}

model CoupleModeConfig {
  id           String   @id @default(uuid())
  familyId     String   @unique
  isActive     Boolean  @default(true)
  splitType    String   @default("equal") // equal | proportional | custom
  participants Json     // [{ personId, proportion, income }]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([familyId])
}

model ExpenseAdjustment {
  id          String   @id @default(uuid())
  familyId    String
  fromPersonId String
  toPersonId  String
  amount      Float
  description String   @default("Ajuste de contas")
  date        DateTime @default(now())
  month       Int
  year        Int
  createdAt   DateTime @default(now())

  @@index([familyId, month, year])
}

model TelegramLink {
  id               String   @id @default(uuid())
  userId           String   @unique
  telegramUserId   String   @unique
  telegramChatId   String
  telegramUsername String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@index([telegramUserId])
}

model TelegramActivationCode {
  id        String   @id @default(uuid())
  userId    String   @unique
  code      String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([code])
}

model TelegramPendingAction {
  id             String   @id @default(uuid())
  userId         String
  telegramChatId String
  actionType     String
  payload        Json
  status         String   @default("pending")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId, status])
  @@index([telegramChatId, status])
}
