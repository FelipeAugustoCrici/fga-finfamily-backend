# ============================================
# AMBIENTE DE DESENVOLVIMENTO (SQLite)
# ============================================
# Para desenvolvimento local, use (já configurado no .env):
DATABASE_URL="file:./prisma/dev.db"

# ============================================
# AMBIENTE DE PRODUÇÃO (AWS RDS PostgreSQL)
# ============================================
# ⚠️ IMPORTANTE: A URL de produção deve ser configurada apenas no
# GitHub Secrets (DATABASE_URL) e NUNCA commitada no repositório!
#
# Formato:
# DATABASE_URL="postgresql://finfamily:SENHA@finfamily-db.cul2ikgmcmim.us-east-1.rds.amazonaws.com:5432/finfamily?schema=public"
#
# Configure em: GitHub > Settings > Secrets and variables > Actions

# ============================================
# CONFIGURAÇÕES DO SERVIDOR
# ============================================
PORT=3333
NODE_ENV=production

# ============================================
# AWS COGNITO (Autenticação)
# ============================================
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_REGION=us-east-1

# ============================================
# AWS EC2 DEPLOY
# ============================================
# Essas variáveis são usadas apenas no GitHub Actions
# EC2_HOST=seu-ip-ec2
# EC2_USERNAME=ec2-user
# EC2_SSH_KEY=-----BEGIN OPENSSH PRIVATE KEY-----
